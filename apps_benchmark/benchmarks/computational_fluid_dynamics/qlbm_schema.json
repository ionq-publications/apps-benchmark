{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QLBM Reference Instance Schema",
  "description": "Schema for the upstream qlbm_instance.json payload. apps-benchmark may add an optional instance_id when this payload is checked into the built-in registry.",
  "type": "object",
  "required": [
    "benchmark_category",
    "problem_type",
    "instance_name",
    "num_qubits",
    "solution_algorithms",
    "data"
  ],
  "properties": {
    "benchmark_category": {
      "const": "computational_fluid_dynamics"
    },
    "problem_type": {
      "const": "quantum_lattice_boltzmann_method"
    },
    "instance_name": {
      "type": "string"
    },
    "num_qubits": {
      "type": "integer",
      "minimum": 1
    },
    "solution_algorithms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "instance_id": {
      "type": "string",
      "description": "Optional apps-benchmark registry identifier added to checked-in benchmark cases."
    },
    "open_solution_algorithms": {
      "type": "array",
      "description": "Optional list of solution_algorithms that are tagged as open benchmarks and require a user-provided solver.",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "data": {
      "type": "object",
      "required": [
        "grid size",
        "spatial dimension",
        "directions",
        "cs",
        "w",
        "e",
        "u",
        "initial state"
      ],
      "properties": {
        "grid size": {
          "type": "integer",
          "minimum": 1
        },
        "spatial dimension": {
          "type": "integer",
          "minimum": 1
        },
        "directions": {
          "type": "integer",
          "minimum": 1
        },
        "cs": {
          "type": "number"
        },
        "w": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "e": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "u": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "initial state": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    }
  }
}
